---
---
<aside
  id="sidebar-mobile"
  class="fixed top-[72px] h-[calc(100vh-72px)] w-44
         bg-[var(--sidebar)]
         border-l border-[var(--sidebar-border)]
         shadow-lg transition-transform duration-300 ease-in-out z-999
         right-0 translate-x-full block md:hidden
         rounded-l-md overflow-y-auto"
>
  <div class="p-3 text-[var(--sidebar-foreground)]">
    <nav class="space-y-1 font-medium text-sm">

      <a href="/#home" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9,22 9,12 15,12 15,22"></polyline>
        </svg>
        <span>首页</span>
      </a>

      <div class="mt-2 pt-2 border-t border-[var(--sidebar-border)]/30">
        <p class="text-[10px] text-[var(--sidebar-foreground)]/50 px-3 mb-1">功能</p>

        <a href="/#works" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
          <span>作品库</span>
        </a>

        <a href="/#upload" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" x2="12" y1="3" y2="15"></line>
          </svg>
          <span>上传作品</span>
        </a>
      </div>

      <div class="mt-2 pt-2 border-t border-[var(--sidebar-border)]/30">
        <p class="text-[10px] text-[var(--sidebar-foreground)]/50 px-3 mb-1">工具</p>

        <a href="/#science" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m12 2 2 5h5l-4 4 1 5-4-3-4 3 2-5-4-4h5z"></path>
          </svg>
          <span>非遗科普</span>
        </a>

        <a href="/#identify" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12h5"></path>
            <path d="m17 12 5 0"></path>
            <path d="M12 2v5"></path>
            <path d="M12 17v5"></path>
            <circle cx="12" cy="12" r="5"></circle>
          </svg>
          <span>技艺识别</span>
        </a>
      </div>

      <div class="mt-2 pt-2 border-t border-[var(--sidebar-border)]/30">
        <p class="text-[10px] text-[var(--sidebar-foreground)]/50 px-3 mb-1">我的</p>

        <a href="/profile" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--sidebar-accent)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span>个人主页</span>
        </a>
      </div>

    </nav>
  </div>
</aside>