---
---
<aside
  id="sidebar"
  class="fixed top-[72px] h-[calc(100vh-72px)] w-48
            bg-[var(--sidebar)]
            border-l border-[var(--sidebar-border)]
            shadow-lg shadow-[var(--sidebar-border)]/10
            transition-all duration-300 ease-in-out z-999
            hidden md:block
            left-0 -translate-x-[calc(100%-8px)] hover:translate-x-0
            rounded-l-md overflow-y-auto"
>
  <div class="p-4 w-full text-[var(--sidebar-foreground)]">
    <nav class="space-y-2">
      <!-- 侧边栏 首页（逻辑已修复） -->
      <a
        href="/#home"
        class="sidebar-home flex items-center gap-3 px-3 py-2 rounded-lg
                            hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                            transition-colors duration-200 font-medium md:font-bold"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9,22 9,12 15,12 15,22"></polyline>
        </svg>
        首页
      </a>

      <div class="mt-4 pt-2 border-t border-[var(--sidebar-border)]/30">
        <p class="text-xs text-[var(--sidebar-foreground)]/60 px-3 mb-2 font-medium md:font-bold">辅助工具</p>
        <a
          href="/knowledge"
          class="flex items-center gap-3 px-3 py-2 rounded-lg
                              hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                              transition-colors duration-200 font-medium md:font-bold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m12 2 2 5h5l-4 4 1 5-4-3-4 3 2-5-4-4h5z"></path>
          </svg>
          非遗科普
        </a>
        <a
          href="/community"
          class="flex items-center gap-3 px-3 py-2 rounded-lg
                              hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                              transition-colors duration-200 font-medium md:font-bold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 18a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2"></path>
            <circle cx="12" cy="7" r="4"></circle>
            <path d="M7 21v-2a5 5 0 0 1 10 0v2"></path>
          </svg>
          传承社区
        </a>
      </div>

      <div class="mt-4 pt-2 border-t border-[var(--sidebar-border)]/30">
        <p class="text-xs text-[var(--sidebar-foreground)]/60 px-3 mb-2 font-medium md:font-bold">个人中心</p>
        <a
          href="/profile"
          class="flex items-center gap-3 px-3 py-2 rounded-lg
                              hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                              transition-colors duration-200 font-medium md:font-bold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          个人主页
        </a>
        <a
          href="/upload"
          class="flex items-center gap-3 px-3 py-2 rounded-lg
                              hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                              transition-colors duration-200 font-medium md:font-bold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" x2="12" y1="3" y2="15"></line>
          </svg>
          上传作品
        </a>
        <a
          href="/settings"
          class="flex items-center gap-3 px-3 py-2 rounded-lg
                              hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                              transition-colors duration-200 font-medium md:font-bold"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1-2 0l-.43.25a2 2 0 0 1-1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
          设置
        </a>
      </div>
    </nav>
  </div>
</aside>

<!-- 侧边栏首页点击逻辑（和顶部导航完全同步） -->
<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const sidebarHomeLink = document.querySelector('#sidebar a[href="/#home"]');
  if (sidebarHomeLink) {
    sidebarHomeLink.addEventListener('click', (e) => {
      // 如果当前已经在首页，阻止跳转，直接回到顶部并展开
      if (window.location.pathname === '/') {
        e.preventDefault();
        window.scrollTo({ top: 0 });
        setTimeout(() => window.expandHeroGlobal?.(), 100);
      }
    });
  }
});
</script>