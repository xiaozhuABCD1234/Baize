<!-- 国风侧边栏：默认露出8px半透明边缘 -->
<aside
  id="sidebar"
  class="fixed top-[72px] h-[calc(100vh-72px)] w-40
            bg-[var(--sidebar)]
            border-r border-[var(--sidebar-border)]
            shadow-lg shadow-[var(--sidebar-border)]/10
            transition-all duration-300 ease-in-out z-40
            left-0 -translate-x-[calc(100%-8px)] hover:translate-x-0
            rounded-r-md"
>
  <div class="p-4 w-full text-[var(--sidebar-foreground)]">
    <nav class="space-y-2">
      <!-- 首页 -->
      <a
        href="#home"
        class="sidebar-home flex items-center gap-3 px-3 py-2 rounded-lg
                            hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                            transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9,22 9,12 15,12 15,22"></polyline>
        </svg>
        首页
      </a>
      <!-- 推荐 -->
      <a
        href="#recommend"
        class="flex items-center gap-3 px-3 py-2 rounded-lg
                            hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                            transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M14.828 14.828a4 4 0 0 1-5.656 0"></path>
          <path
            d="M9 10h1.586a1 1 0 0 1 .707.293l.707.707a1 1 0 0 0 1.414-1.414H15a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2v-1a2 2 0 0 1 2-2Z"
          ></path>
          <path d="M16 5V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v1"></path>
        </svg>
        推荐
      </a>
      <!-- 关注 -->
      <a
        href="#following"
        class="flex items-center gap-3 px-3 py-2 rounded-lg
                            hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                            transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M22 2l-4.5 4.5L15 6"></path>
        </svg>
        关注
      </a>
      <!-- 分类 -->
      <a
        href="#categories"
        class="flex items-center gap-3 px-3 py-2 rounded-lg
                            hover:bg-[var(--sidebar-accent)] hover:text-[var(--sidebar-accent-foreground)]
                            transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="7" height="7" x="3" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="14" rx="1"></rect>
          <rect width="7" height="7" x="3" y="14" rx="1"></rect>
        </svg>
        分类
      </a>
    </nav>
  </div>
</aside>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const homeLink = document.querySelector(".sidebar-home");
    const hero = document.getElementById("hero-container");

    if (homeLink && hero) {
      homeLink.addEventListener("click", (e) => {
        e.preventDefault();

        // 检查 hero 容器是否已展开（通过类名判断）
        const heroContainer = document.getElementById("hero-container");
        if (heroContainer && heroContainer.classList.contains("expanded")) {
          return;
        }

        window.scrollTo({ top: 0, behavior: "smooth" });
        setTimeout(() => {
          hero.click();
        }, 100);
      });
    }
  });
</script>
