---
import { craftService } from "../services";
import type { Craft } from "../services";

// 传承人类型定义
interface Inheritor {
  id: string;
  name: string;
  title: string;
  specialty: string;
  imageUrl: string;
  experience: string;
}

// 项目类型定义
interface Project {
  id: string;
  title: string;
  category: string;
  summary: string;
  coverUrl: string;
  likes: number;
}

// 从API获取技艺数据
let crafts: Craft[] = [];
try {
  crafts = await craftService.list();
} catch (error) {
  console.error('Error fetching crafts:', error);
  crafts = [];
}

// 模拟传承人数据（暂时使用模拟数据，因为没有专门的传承人API）
const inheritors: Inheritor[] = [];

// 准备项目数据（使用技艺数据）
const projects: Project[] = crafts.map(craft => ({
  id: craft.id.toString(),
  title: craft.name,
  category: craft.category?.name || "未知分类",
  summary: craft.description || "暂无描述",
  coverUrl: `https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=${encodeURIComponent(craft.name)}%20traditional%20chinese%20craft&image_size=square_hd`,
  likes: Math.floor(Math.random() * 500) + 100
}));
---

<section id="内容推荐" class="py-16 md:py-24 bg-muted/20">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-foreground mb-4">内容推荐</h2>
      <p class="text-lg text-muted-foreground">精选非遗作品与知识科普，品味传统文化之美</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <div>
        <div class="flex items-center mb-6">
          <h3 class="font-heading text-2xl font-semibold text-foreground flex items-center gap-3">
            <span class="w-1.5 h-8 bg-primary rounded-full"></span>
            非遗传承人
          </h3>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {inheritors.length > 0 ? (
            inheritors.map(inheritor => (
              <div class="bg-card rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                <img src={inheritor.imageUrl} alt={inheritor.name} class="w-full h-32 object-cover">
                <div class="p-3">
                  <h4 class="text-sm font-medium line-clamp-1">{inheritor.name}</h4>
                  <p class="text-xs text-muted-foreground mb-2">{inheritor.title}</p>
                  <div class="flex items-center justify-between text-xs text-muted-foreground">
                    <span>{inheritor.specialty}</span>
                    <span>从业{inheritor.experience}</span>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="col-span-2 bg-card rounded-lg p-8 text-center">
              <p class="text-muted-foreground">暂无传承人数据</p>
            </div>
          )}
        </div>
      </div>

      <div>
        <div class="flex items-center mb-6">
          <h3 class="font-heading text-2xl font-semibold text-foreground flex items-center gap-3">
            <span class="w-1.5 h-8 bg-secondary rounded-full"></span>
            非遗项目
          </h3>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {projects.length > 0 ? (
            projects.map(project => (
              <div class="bg-card rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                <img src={project.coverUrl} alt={project.title} class="w-full h-32 object-cover">
                <div class="p-3">
                  <h4 class="text-sm font-medium line-clamp-1">{project.title}</h4>
                  <p class="text-xs text-muted-foreground mb-2">{project.category}</p>
                  <div class="flex items-center justify-between text-xs text-muted-foreground">
                    <span class="flex items-center gap-1">❤️ {project.likes}</span>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="col-span-2 bg-card rounded-lg p-8 text-center">
              <p class="text-muted-foreground">暂无项目数据</p>
            </div>
          )}
        </div>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a href="/knowledge" class="inline-block px-6 py-3 bg-primary text-primary-foreground rounded-full hover:bg-primary/90 transition-colors font-medium">
        进入科普界面
      </a>
    </div>
  </div>
</section>