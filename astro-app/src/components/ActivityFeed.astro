---
type Activity = {
  id: string;
  user: {
    name: string;
    avatar: string;
  };
  type: "upload" | "comment" | "like";
  content: string;
  time: string;
  imageUrl?: string;
  likes: number;
  comments: number;
};

import ActivityCard from "./ActivityCard.astro";
import { craftService } from "../services";
import type { Craft } from "../services";

// 从API获取技艺数据，转换为活动数据
let activities: Activity[] = [];
try {
  const crafts: Craft[] = await craftService.list();
  activities = crafts.map((craft, index) => ({
    id: craft.id.toString(),
    user: {
      name: `技艺传承人${index + 1}`,
      avatar: `https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face`
    },
    type: "upload" as const,
    content: `分享了${craft.name}的制作技艺，${craft.description || "这是一项传统技艺"}`,
    time: `${Math.floor(Math.random() * 24)}小时前`,
    imageUrl: `https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=${encodeURIComponent(craft.name)}%20traditional%20chinese%20craft&image_size=square`,
    likes: Math.floor(Math.random() * 300) + 50,
    comments: Math.floor(Math.random() * 100) + 10
  }));
} catch (error) {
  console.error('Error fetching activities:', error);
  activities = [];
}
---

<section id="社区动态" class="py-16 md:py-24 bg-background">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-semibold text-foreground mb-4">社区动态</h2>
      <p class="text-lg text-muted-foreground">看看传承人和爱好者们最近在做什么</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {activities.length > 0 ? (
        activities.map(activity => (
          <ActivityCard activity={activity} />
        ))
      ) : (
        <div class="col-span-full bg-card rounded-xl p-8 text-center">
          <p class="text-muted-foreground">暂无社区动态</p>
        </div>
      )}
    </div>

    <div class="text-center mt-10">
      <a href="/community" class="inline-flex items-center gap-2 text-lg text-primary hover:underline font-medium">
        查看全部动态
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>