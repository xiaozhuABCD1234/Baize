---
interface Props {
  id: string;
  title: string;
  description: string;
  icon: string;
}

const { id, title, description, icon } = Astro.props;
---

<a href={`/knowledge/${id}`} class="block bg-card rounded-xl overflow-hidden shadow hover:shadow-md transition-all border border-border">
  <div class="h-48 bg-muted/30 flex items-center justify-center">
    <div set:html={icon}></div>
  </div>
  <div class="p-5">
    <h3 class="text-lg font-semibold mb-2">{title}</h3>
    <p class="text-sm text-muted-foreground line-clamp-3">
      {description}
    </p>
  </div>
</a>
