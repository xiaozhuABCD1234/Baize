---
interface Work {
  id: string;
  title: string;
  author: string;
  imageUrl: string;
  likes: number;
  category: string;
}

interface Article {
  id: string;
  title: string;
  category: string;
  summary: string;
  coverUrl: string;
  readTime: string;
}

interface Props {
  type: "work" | "article";
  data: Work | Article;
}

const { type, data } = Astro.props;
---

{type === "work" && (
  <a href="#" class="group block rounded-xl overflow-hidden bg-card border border-border/50 hover:border-primary/30 hover:shadow-md transition-all">
    <div class="aspect-4/3 overflow-hidden">
      <img 
        src={(data as Work).imageUrl} 
        alt={(data as Work).title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
    <div class="p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary font-medium">{(data as Work).category}</span>
      </div>
      <h4 class="font-heading text-base font-medium text-foreground mb-1 line-clamp-1">{(data as Work).title}</h4>
      <div class="flex items-center justify-between">
        <span class="text-sm text-muted-foreground">{(data as Work).author}</span>
        <div class="flex items-center gap-1 text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
          </svg>
          <span class="text-sm">{(data as Work).likes}</span>
        </div>
      </div>
    </div>
  </a>
)}

{type === "article" && (
  <a href="#" class="group block rounded-xl overflow-hidden bg-card border border-border/50 hover:border-secondary/30 hover:shadow-md transition-all">
    <div class="aspect-4/3 overflow-hidden">
      <img 
        src={(data as Article).coverUrl} 
        alt={(data as Article).title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
    <div class="p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs px-2 py-0.5 rounded-full bg-secondary/10 text-secondary font-medium">{(data as Article).category}</span>
        <span class="text-xs text-muted-foreground">{(data as Article).readTime}</span>
      </div>
      <h4 class="font-heading text-base font-medium text-foreground mb-1 line-clamp-1">{(data as Article).title}</h4>
      <p class="text-sm text-muted-foreground line-clamp-2">{(data as Article).summary}</p>
    </div>
  </a>
)}

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>