---
import Logo from "./Logo.astro";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import SidebarMobile from "./SidebarMobile.astro";
---

<header class="fixed top-0 z-60 w-full bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-6 lg:px-12">
    <a href="/" class="flex items-center gap-2">
      <Logo />
    </a>

    <!-- 电脑端导航 -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/#home" class="text-lg font-medium transition-colors" data-nav-link="home">首页</a>
      <a href="/knowledge" class="text-lg font-medium transition-colors" data-nav-link="knowledge">科普</a>
      <a href="/community" class="text-lg font-medium transition-colors" data-nav-link="community">社区动态</a>
    </nav>

    <div class="flex items-center gap-4">
      <!-- 手机搜索按钮 -->
      <button class="flex h-11 w-11 items-center justify-center rounded-full hover:bg-muted transition-colors md:hidden" aria-label="搜索" id="mobile-search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      
      <!-- 电脑端搜索+登录注册 -->
      <div class="hidden md:flex items-center gap-3">
        <div class="relative">
          <input 
            type="search" 
            placeholder="搜索非遗..." 
            class="w-[200px] lg:w-[280px] h-11 pl-10 rounded-full border border-border focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
            id="desktop-search-input"
          />
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-[14px] text-muted-foreground">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </div>
        <a href="/MainLayout"><Button variant="outline" size="lg" className="h-11 px-5 text-base">登录</Button></a>
        <a href="/register"><Button size="lg" className="h-11 px-5 text-base">注册</Button></a>
      </div>

      <!-- 手机菜单按钮 -->
      <button 
        id="menuBtn"
        class="flex h-11 w-11 items-center justify-center rounded-full transition-colors md:hidden" 
        aria-label="菜单"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- 搜索弹出面板 -->
<div id="search-panel" class="fixed inset-0 z-500 bg-black/50 flex items-center justify-center hidden overflow-y-auto">
  <div class="bg-background rounded-xl shadow-2xl w-full max-w-2xl mx-4 p-6 my-8 max-h-[80vh] overflow-y-auto">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-xl font-semibold">搜索</h3>
      <button id="close-search-btn" class="text-muted-foreground hover:text-foreground transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" x2="6" y1="6" y2="18"></line>
          <line x1="6" x2="18" y1="6" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="relative mb-6">
      <input 
        type="text" 
        placeholder="搜索非遗内容、传承人、活动..." 
        class="w-full px-4 py-3 pr-10 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
        id="search-input"
      >
      <button class="absolute right-3 top-1/2 transform -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
    </div>
    <div class="space-y-4">
      <div>
        <h4 class="font-medium text-sm mb-3">搜索历史</h4>
        <div class="flex flex-wrap gap-2">
          <button class="text-xs px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors">#苏绣</button>
          <button class="text-xs px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors">#木雕</button>
          <button class="text-xs px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors">#剪纸</button>
          <button class="text-xs px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors">#茶文化</button>
          <button class="text-xs px-3 py-1 bg-muted rounded-full hover:bg-muted/80 transition-colors">#传承人</button>
        </div>
      </div>
      <div>
        <h4 class="font-medium text-sm mb-3">热门搜索</h4>
        <div class="space-y-2">
          <div class="flex items-center justify-between px-2 py-2 hover:bg-muted/50 rounded-md cursor-pointer">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold">1</div>
              <span class="text-sm">非遗传承计划</span>
            </div>
            <span class="text-xs text-muted-foreground">1.2k</span>
          </div>
          <div class="flex items-center justify-between px-2 py-2 hover:bg-muted/50 rounded-md cursor-pointer">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold">2</div>
              <span class="text-sm">苏绣技艺</span>
            </div>
            <span class="text-xs text-muted-foreground">896</span>
          </div>
          <div class="flex items-center justify-between px-2 py-2 hover:bg-muted/50 rounded-md cursor-pointer">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold">3</div>
              <span class="text-sm">木雕艺术</span>
            </div>
            <span class="text-xs text-muted-foreground">754</span>
          </div>
          <div class="flex items-center justify-between px-2 py-2 hover:bg-muted/50 rounded-md cursor-pointer">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center text-muted-foreground text-xs font-bold">4</div>
              <span class="text-sm">剪纸艺术</span>
            </div>
            <span class="text-xs text-muted-foreground">621</span>
          </div>
          <div class="flex items-center justify-between px-2 py-2 hover:bg-muted/50 rounded-md cursor-pointer">
            <div class="flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-muted flex items-center justify-center text-muted-foreground text-xs font-bold">5</div>
              <span class="text-sm">茶文化</span>
            </div>
            <span class="text-xs text-muted-foreground">587</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 引入你的独立侧边栏文件 -->
<SidebarMobile />

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  // 设置导航激活状态
  const setActiveNavLink = () => {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('[data-nav-link]');
    
    navLinks.forEach(link => {
      link.classList.remove('text-primary', 'font-semibold');
      link.classList.add('text-foreground/80', 'hover:text-primary');
    });
    
    if (currentPath === '/') {
      const homeLink = document.querySelector('[data-nav-link="home"]');
      if (homeLink) {
        homeLink.classList.remove('text-foreground/80', 'hover:text-primary');
        homeLink.classList.add('text-primary', 'font-semibold');
      }
    } else if (currentPath === '/knowledge') {
      const knowledgeLink = document.querySelector('[data-nav-link="knowledge"]');
      if (knowledgeLink) {
        knowledgeLink.classList.remove('text-foreground/80', 'hover:text-primary');
        knowledgeLink.classList.add('text-primary', 'font-semibold');
      }
    } else if (currentPath === '/community') {
      const communityLink = document.querySelector('[data-nav-link="community"]');
      if (communityLink) {
        communityLink.classList.remove('text-foreground/80', 'hover:text-primary');
        communityLink.classList.add('text-primary', 'font-semibold');
      }
    }
  };
  
  // 初始化激活状态
  setActiveNavLink();

  // 统一修复所有 首页 点击逻辑（顶部 + 侧边栏）
  const homeLinks = document.querySelectorAll('a[href="/#home"]');
  homeLinks.forEach(link => {
    link.addEventListener("click", (e) => {
      if (window.location.pathname === "/") {
        e.preventDefault();
        window.scrollTo({ top: 0 });
        setTimeout(() => window.expandHeroGlobal?.(), 100);
      }
    });
  });

  // 移动端菜单逻辑（只在手机生效，不影响电脑端）
  const menuBtn = document.getElementById("menuBtn");
  const sidebar = document.getElementById("sidebar-mobile");

  if (menuBtn && sidebar) {
    // 打开/关闭菜单
    menuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      sidebar.classList.toggle("translate-x-full");
    });

    // 点击侧边栏不关闭
    sidebar.addEventListener("click", (e) => {
      e.stopPropagation();
    });

    // 点击空白关闭 → 只在移动端生效，不影响电脑端链接
    document.addEventListener("click", (e) => {
      if (window.innerWidth < 768) {
        sidebar.classList.add("translate-x-full");
      }
    });
  }

  // 搜索面板交互
  const searchPanel = document.getElementById("search-panel");
  const mobileSearchBtn = document.getElementById("mobile-search-btn");
  const desktopSearchInput = document.getElementById("desktop-search-input");
  const closeSearchBtn = document.getElementById("close-search-btn");
  const searchInput = document.getElementById("search-input");

  if (searchPanel && mobileSearchBtn && closeSearchBtn) {
    // 显示搜索面板
    const showSearchPanel = () => {
      searchPanel.classList.remove("hidden");
      document.body.style.overflow = "hidden"; // 防止背景滚动
    };

    // 隐藏搜索面板
    const hideSearchPanel = () => {
      searchPanel.classList.add("hidden");
      document.body.style.overflow = "auto"; // 恢复背景滚动
    };

    // 手机搜索按钮点击
    mobileSearchBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      showSearchPanel();
    });

    // 电脑端搜索输入框点击
    if (desktopSearchInput) {
      desktopSearchInput.addEventListener("click", (e) => {
        e.stopPropagation();
        showSearchPanel();
      });
    }

    // 关闭按钮点击
    closeSearchBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      hideSearchPanel();
    });

    // 点击面板外部关闭
    searchPanel.addEventListener("click", (e) => {
      if (e.target === searchPanel) {
        hideSearchPanel();
      }
    });

    // 搜索按钮点击
    const searchButton = searchPanel.querySelector('button[class*="absolute right-3"]');
    if (searchButton) {
      searchButton.addEventListener('click', () => {
        if (searchInput) {
          const searchTerm = searchInput.value.trim();
          if (searchTerm) {
            // 跳转到搜索结果页面
            window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
          }
        }
      });
    }

    // 搜索输入框回车
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const searchTerm = searchInput.value.trim();
        if (searchTerm) {
          // 跳转到搜索结果页面
          window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
        }
      }
    });

    // 搜索历史点击
    const historyTags = searchPanel.querySelectorAll('.text-xs.px-3.py-1.bg-muted.rounded-full');
    historyTags.forEach((tag) => {
      tag.addEventListener('click', () => {
        const tagText = tag.textContent;
        if (tagText) {
          // 跳转到搜索结果页面
          window.location.href = `/search?q=${encodeURIComponent(tagText.trim())}`;
        }
      });
    });

    // 热门搜索点击
    const hotSearches = searchPanel.querySelectorAll('.space-y-2 > div');
    hotSearches.forEach((item) => {
      item.addEventListener('click', () => {
        const searchText = item.querySelector('span.text-sm')?.textContent;
        if (searchText) {
          // 跳转到搜索结果页面
          window.location.href = `/search?q=${encodeURIComponent(searchText.trim())}`;
        }
      });
    });
  }
});
</script>