---
import Layout from "../../layouts/Layout.astro";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import ActivityFeed from "@/components/ActivityFeed.astro";
import Footer from "@/components/Footer.astro";
import { knowledgeItems, getKnowledgeItems } from "@/data/knowledge";

export function getStaticPaths() {
  return knowledgeItems.map(item => ({
    params: { id: item.id }
  }));
}

const { id } = Astro.params;
// 获取科普数据
const items = await getKnowledgeItems();
const knowledgeItem = items.find(item => item.id === id);

if (!knowledgeItem) {
  return Astro.redirect("/knowledge");
}
---

<Layout>
	<Header />
	<Sidebar />

	<aside id="activity-sidebar" class="fixed -right-80 top-[72px] h-[calc(100vh-72px)] w-80 bg-background border-l border-border/50 transition-all duration-300 ease-in-out hover:right-0 z-40">
		<div class="p-4 h-full overflow-y-auto">
			<ActivityFeed />
		</div>
	</aside>

	<main class="pt-[100px] w-full max-w-[1800px] mx-auto px-4 lg:px-6 relative z-50">
		<!-- 返回按钮 -->
		<div class="mb-6 relative z-50">
			<script>
				// 获取 URL 中的 ref 参数
				const urlParams = new URLSearchParams(window.location.search);
				const ref = urlParams.get('ref');
				// 设置返回链接
				const backLink = ref || '/knowledge';
				// 检查元素是否存在
				const backButton = document.querySelector('.back-button');
				const backText = document.querySelector('.back-text');
				if (backButton && backButton instanceof HTMLAnchorElement) {
					backButton.href = backLink;
				}
				if (backText && backText instanceof HTMLElement) {
					backText.textContent = ref ? '返回搜索结果' : '返回科普列表';
				}
			</script>
			<a href="" class="back-button inline-flex items-center gap-2 px-3 py-2 rounded-md bg-card text-foreground hover:bg-muted border border-border transition-all">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M19 12H5"></path>
					<path d="M12 19l-7-7 7-7"></path>
				</svg>
				<span class="back-text">返回科普列表</span>
			</a>
		</div>

		<!-- 科普详情页面 -->
		<section id="科普详情" class="py-5 bg-background min-h-screen">
			<div class="mx-auto max-w-4xl px-6 lg:px-8">
				<!-- 标题区域 -->
				<div class="text-center mb-10">
					<div class="flex justify-center mb-6">
						<div class="h-32 w-32 bg-muted/30 flex items-center justify-center rounded-full">
							<div set:html={knowledgeItem.icon}></div>
						</div>
					</div>
					<h1 class="font-heading text-3xl md:text-4xl font-semibold text-foreground mb-6">
						{knowledgeItem.title}
					</h1>
					<div class="w-20 h-1 bg-primary mx-auto mb-8"></div>
				</div>

				<!-- 内容区域 -->
				<div class="bg-card rounded-xl p-8 shadow border border-border mb-8">
					<div class="prose max-w-none">
						<p class="text-lg mb-6">{knowledgeItem.description}</p>
					</div>
				</div>

				<!-- 非遗介绍板块 -->
				<div class="bg-card rounded-xl p-8 shadow border border-border mb-8">
					<h2 class="text-2xl font-semibold mb-6 text-foreground">非遗介绍</h2>
					<div class="space-y-6">
						<div>
							<h3 class="text-xl font-medium mb-3 text-primary">起源</h3>
							<p class="text-muted-foreground">{knowledgeItem.details.origin}</p>
						</div>
						<div>
							<h3 class="text-xl font-medium mb-3 text-primary">历史</h3>
							<p class="text-muted-foreground">{knowledgeItem.details.history}</p>
						</div>
						<div>
							<h3 class="text-xl font-medium mb-3 text-primary">特点</h3>
							<p class="text-muted-foreground">{knowledgeItem.details.features}</p>
						</div>
						<div>
							<h3 class="text-xl font-medium mb-3 text-primary">意义</h3>
							<p class="text-muted-foreground">{knowledgeItem.details.significance}</p>
						</div>
					</div>
				</div>

				<!-- 人物介绍板块 -->
				{knowledgeItem.inheritors && knowledgeItem.inheritors.length > 0 && (
					<div class="bg-card rounded-xl p-8 shadow border border-border">
						<h2 class="text-2xl font-semibold mb-6 text-foreground">人物介绍</h2>
						<div class="space-y-8">
							{knowledgeItem.inheritors.map((inheritor, index) => (
								<div class="border-b border-border pb-6 last:border-0 last:pb-0">
									<h3 class="text-xl font-medium mb-2 text-primary">{inheritor.name}</h3>
									<p class="text-sm text-muted-foreground mb-3">{inheritor.title}</p>
									<div class="space-y-3">
										<div>
											<h4 class="font-medium mb-1">简介</h4>
											<p class="text-muted-foreground">{inheritor.bio}</p>
										</div>
										<div>
											<h4 class="font-medium mb-1">贡献</h4>
											<p class="text-muted-foreground">{inheritor.contributions}</p>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				)}

				<!-- 其他推荐 -->
				<div class="mt-12">
					<h3 class="text-xl font-semibold mb-6">其他推荐</h3>
					<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
						{items.filter(item => item.id !== id).slice(0, 3).map((item) => (
							<a href={`/knowledge/${item.id}`} class="block bg-card rounded-lg p-4 shadow hover:shadow-md transition-all border border-border">
								<h4 class="font-semibold mb-2">{item.title}</h4>
								<p class="text-sm text-muted-foreground line-clamp-2">{item.description}</p>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
