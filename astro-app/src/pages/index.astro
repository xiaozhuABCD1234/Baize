---
import Layout from "../layouts/Layout.astro";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import Hero from "@/components/Hero.astro";
import FeatureSection from "@/components/FeatureSection.astro";
import ContentStream from "@/components/ContentStream.astro";
import ActivityFeed from "@/components/ActivityFeed.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
	<Header />
	<Sidebar />

	<main class="pt-4 w-full max-w-[1800px] mx-auto px-4 lg:px-6">
		<div id="hero-container" class="collapsed relative cursor-pointer">
			<Hero />
			<button id="collapse-button" class="hero-collapse-button hidden absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-background/90 px-5 py-2 text-sm font-medium text-foreground shadow-lg transition-opacity duration-300 hover:bg-background">
				收起
			</button>
		</div>

		<div class="flex">
			<div class="flex-1">
				<FeatureSection />
				<ContentStream />
			</div>
		</div>

		<div class="mt-16 mb-8">
			<ActivityFeed />
		</div>
	</main>

	<Footer />
</Layout>

<script is:inline>
	const heroContainer = document.getElementById('hero-container');
	const heroContent = document.getElementById('hero-content');
	const collapseButton = document.getElementById('collapse-button');
	const main = document.querySelector('main');

	let isExpanded = false;
	let scrollCheckTimer = null;
	let isInternalJump = false;

	window.addEventListener('hashchange', (e) => {
		if (window.location.hash === '#home') isInternalJump = true;
	});
	window.addEventListener('popstate', (e) => {
		if (window.location.pathname === '/' || window.location.hash === '#home') isInternalJump = true;
	});

	const STORAGE_KEY = 'hero_home_state';

	const collapseHero = () => {
		heroContainer.classList.add('collapsed');
		heroContainer.classList.remove('expanded');
		heroContainer.style.position = 'fixed';
		heroContainer.style.top = '68px';
		heroContainer.style.left = '0';
		heroContainer.style.right = '0';
		heroContainer.style.zIndex = '30';
		heroContainer.style.background = 'rgba(249, 250, 251, 0.8)';
		heroContainer.style.backdropFilter = 'blur(8px)';
		heroContainer.style.maxHeight = '90px';
		heroContainer.style.overflow = 'hidden';
		heroContent.style.maxHeight = '60px';
		heroContent.style.opacity = '1';
		if (collapseButton) collapseButton.classList.add('hidden');
		if (main) main.style.paddingTop = '90px';
		isExpanded = false;
	};

	const expandHero = () => {
		heroContainer.classList.remove('collapsed');
		heroContainer.classList.add('expanded');
		heroContainer.style.position = 'relative';
		heroContainer.style.top = 'auto';
		heroContainer.style.maxHeight = '100vh';
		heroContainer.style.overflow = 'hidden';
		heroContent.style.maxHeight = heroContent.scrollHeight + 'px';
		heroContent.style.opacity = '1';
		if (collapseButton) collapseButton.classList.remove('hidden');
		if (main) main.style.paddingTop = '1rem';
		isExpanded = true;
	};

	const scrollToTopAndExpand = () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
		setTimeout(() => {
			expandHero();
		}, 250);
	};

	window.expandHeroGlobal = scrollToTopAndExpand;
	window.collapseHeroGlobal = collapseHero;

	if (heroContainer && heroContent) {
		heroContainer.style.transition = 'none';
		heroContent.style.transition = 'none';

		const savedState = localStorage.getItem(STORAGE_KEY);
		const isFromExternal = document.referrer && !document.referrer.includes(window.location.host);

		setTimeout(() => {
			// 👇 核心修改：默认直接展开，不再默认收起
			window.scrollTo(0, 0);
			expandHero();
			isInternalJump = false;

			// 如果你想保留记住上次滚动状态，把上面注释，打开下面这段
			// if (savedState) {
			// 	const { expanded, scrollY } = JSON.parse(savedState);
			// 	window.scrollTo(0, scrollY);
			// 	expanded ? expandHero() : collapseHero();
			// } else {
			// 	// 无缓存 → 默认展开
			// 	window.scrollTo(0, 0);
			// 	expandHero();
			// }

			setTimeout(() => {
				heroContainer.style.transition = 'max-height 0.5s ease-out, background 0.3s ease';
				heroContent.style.transition = 'max-height 0.5s ease-out, opacity 0.3s ease';
			}, 50);

		}, 0);

		heroContainer.addEventListener('click', () => {
			if (!isExpanded) scrollToTopAndExpand();
		});

		let scrollDebounce;
		window.addEventListener('scroll', () => {
			clearTimeout(scrollDebounce);
			scrollDebounce = setTimeout(() => {
				if (isExpanded && window.scrollY > 30) {
					collapseHero();
					localStorage.setItem(STORAGE_KEY, JSON.stringify({ expanded: false, scrollY: window.scrollY }));
				}
			}, 100);
		});

		if (collapseButton) {
			collapseButton.addEventListener('click', (e) => {
				e.stopPropagation();
				collapseHero();
				localStorage.setItem(STORAGE_KEY, JSON.stringify({ expanded: false, scrollY: window.scrollY }));
			});
		}
	}
</script>

<style is:global>
	#hero-container.expanded { position: relative; }
	#hero-container.expanded section { min-height: 100vh; }

	#hero-container.collapsed .hero-subtitle {
		display: none !important;
		visibility: hidden !important;
		opacity: 0 !important;
		height: 0 !important;
		margin: 0 !important;
		padding: 0 !important;
	}

	#hero-container.collapsed section {
		padding-top: 0.8rem;
		padding-bottom: 0.8rem;
		text-align: center;
	}

	#hero-container.collapsed .hero-title {
		font-size: 1.7rem;
		margin-bottom: 0 !important;
		line-height: 1.2;
		font-weight: 600;
	}

	#hero-container.collapsed .hero-actions {
		opacity: 0;
		max-height: 0;
		overflow: hidden;
	}

	#hero-container.collapsed .absolute.inset-0,
	#hero-container.collapsed .absolute.bottom-0 {
		opacity: 0 !important;
		pointer-events: none;
	}

	#hero-container { cursor: pointer; }
	#hero-container .hero-collapse-button { pointer-events: auto; }
	html, body { overflow-x: hidden; }
	html { scroll-behavior: smooth; }
</style>