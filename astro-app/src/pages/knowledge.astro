---
import Layout from "../layouts/Layout.astro";
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import ActivityFeed from "@/components/ActivityFeed.astro";
import Footer from "@/components/Footer.astro";
import KnowledgeCard from "@/components/KnowledgeCard.astro";
import { getKnowledgeItems, knowledgeItems } from "@/data/knowledge";

// 获取科普数据
const items = await getKnowledgeItems();
---

<Layout>
	<Header />
	<Sidebar />

	<aside id="activity-sidebar" class="fixed -right-80 top-[72px] h-[calc(100vh-72px)] w-80 bg-background border-l border-border/50 transition-all duration-300 ease-in-out hover:right-0 z-40">
		<div class="p-4 h-full overflow-y-auto">
			<ActivityFeed />
		</div>
	</aside>

	<main class="pt-[100px] w-full max-w-[1800px] mx-auto px-4 lg:px-6 relative z-50">
		<!-- 返回按钮 -->
		<div class="mb-6 relative z-50">
			<a href="/#home" class="inline-flex items-center gap-2 px-3 py-2 rounded-md bg-card text-foreground hover:bg-muted border border-border transition-all">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M19 12H5"></path>
					<path d="M12 19l-7-7 7-7"></path>
				</svg>
				<span>返回首页</span>
			</a>
		</div>

		<!-- 🔥 小红书/B站风格 科普页面 -->
		<section id="科普" class="py-5 bg-background min-h-screen">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				
				<!-- 标题区域（和你内容推荐板块完全同款） -->
				<div class="text-center mb-10">
					<h2 class="font-heading text-3xl md:text-4xl font-semibold text-foreground mb-4">
						非遗知识科普
					</h2>
					<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
						一站式了解非遗文化、技艺与历史内涵
					</p>
				</div>

				<!-- 选项卡切换 -->
				<div class="mb-8">
					<div class="flex justify-center gap-4">
						<button id="tab-people" class="tab-btn px-8 py-4 rounded-xl font-semibold transition-all duration-300 bg-primary text-white shadow-lg hover:shadow-xl hover:scale-105 active:scale-105" onclick="switchTab('people')">
							非遗传承人
						</button>
						<button id="tab-projects" class="tab-btn px-8 py-4 rounded-xl font-semibold transition-all duration-300 bg-muted text-muted-foreground shadow hover:shadow-md hover:bg-muted/80 hover:scale-105 active:scale-105" onclick="switchTab('projects')">
							非遗项目
						</button>
					</div>
				</div>

				<!-- 非遗人介绍区域 -->
				<div id="content-people" class="content-section">
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						<!-- 提取所有传承人 -->
						{items
							.filter(item => item.inheritors && item.inheritors.length > 0)
							.flatMap(item => item.inheritors!.map(inheritor => ({
								...inheritor,
								非遗项目: item.title,
								非遗项目ID: item.id
							})))
							.map((inheritor, index) => (
								<div class="bg-card rounded-xl overflow-hidden shadow hover:shadow-md transition-all border border-border p-6">
									<h4 class="text-xl font-semibold mb-2 text-primary">{inheritor.name}</h4>
									<p class="text-sm text-muted-foreground mb-3">{inheritor.title}</p>
									<p class="text-sm text-muted-foreground mb-3">所属项目：{inheritor.非遗项目}</p>
									<p class="text-sm text-muted-foreground line-clamp-3 mb-4">{inheritor.bio}</p>
									<a href={`/people/${inheritor.id}`} class="text-sm text-primary hover:underline">查看详情</a>
								</div>
							))}
					</div>
				</div>

				<!-- 非遗项目介绍区域 -->
				<div id="content-projects" class="content-section hidden">
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{items.map((item) => (
							<KnowledgeCard
								id={item.id}
								title={item.title}
								description={item.description}
								icon={item.icon}
							/>
						))}
					</div>
				</div>

				<!-- 选项卡切换脚本 -->
				<script is:inline>
					function switchTab(tab) {
						const peopleBtn = document.getElementById('tab-people');
						const projectsBtn = document.getElementById('tab-projects');
						const peopleContent = document.getElementById('content-people');
						const projectsContent = document.getElementById('content-projects');

						if (tab === 'people') {
							peopleBtn.classList.add('bg-primary', 'text-foreground');
							peopleBtn.classList.remove('bg-muted', 'text-muted-foreground');
							projectsBtn.classList.remove('bg-primary', 'text-foreground');
							projectsBtn.classList.add('bg-muted', 'text-muted-foreground');
							peopleContent.classList.remove('hidden');
							projectsContent.classList.add('hidden');
						} else {
							projectsBtn.classList.add('bg-primary', 'text-foreground');
							projectsBtn.classList.remove('bg-muted', 'text-muted-foreground');
							peopleBtn.classList.remove('bg-primary', 'text-foreground');
							peopleBtn.classList.add('bg-muted', 'text-muted-foreground');
							projectsContent.classList.remove('hidden');
							peopleContent.classList.add('hidden');
						}
					}
				</script>
			</div>
		</section>
	</main>

</Layout>