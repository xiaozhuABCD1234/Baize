---
import Layout from "../layouts/Layout.astro"; // 👈 已改名
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import ActivityFeed from "@/components/ActivityFeed.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>  <!-- 👈 已同步改名 -->
	<Header />
	<Sidebar />

	<aside id="activity-sidebar" class="fixed -right-80 top-[72px] h-[calc(100vh-72px)] w-80 bg-background border-l border-border/50 transition-all duration-300 ease-in-out hover:right-0 z-40">
		<div class="p-4 h-full overflow-y-auto">
			<ActivityFeed />
		</div>
	</aside>

	<main class="pt-[100px] w-full max-w-[1800px] mx-auto px-4 lg:px-6 relative z-50">
		<!-- 返回按钮 -->
		<div class="mb-6 relative z-10">
			<a href="/#home" class="inline-flex items-center gap-2 px-3 py-2 rounded-md bg-card text-foreground hover:bg-muted border border-border transition-all">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M19 12H5"></path>
					<path d="M12 19l-7-7 7-7"></path>
				</svg>
				<span>返回首页</span>
			</a>
		</div>

		<!-- 🔥 登录页面主布局 -->
		<section id="登录" class="py-5 bg-background flex items-center justify-center">
			<div class="w-full max-w-md px-4">
				<!-- 登录卡片 -->
				<div class="bg-card rounded-2xl p-6 shadow-lg border border-border overflow-hidden relative">
					<!-- 装饰背景 -->
					<div class="absolute inset-0 opacity-10 bg-gradient-to-br from-primary/40 to-background"></div>

					<div class="relative z-10 space-y-6">
						<!-- 标题区域 -->
						<div class="text-center space-y-2">
							<h1 class="text-2xl font-bold font-heading text-foreground">欢迎回来</h1>
							<p class="text-sm text-muted-foreground">登录后即可管理您的苏绣作品与账号</p>
						</div>

						<!-- 登录表单 -->
						<form class="space-y-5">
							<!-- 邮箱输入框 -->
							<div class="space-y-1.5">
								<label class="text-sm font-medium text-foreground">邮箱</label>
								<div class="relative">
									<div class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
											<polyline points="22,6 12,13 2,6"></polyline>
										</svg>
									</div>
									<input
										type="email"
										placeholder="请输入您的邮箱"
										class="w-full pl-10 pr-4 py-2.5 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
									/>
								</div>
							</div>

							<!-- 密码输入框 -->
							<div class="space-y-1.5">
								<label class="text-sm font-medium text-foreground">密码</label>
								<div class="relative">
									<div class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap:round stroke-linejoin:round>
											<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
											<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
										</svg>
									</div>
									<input
										type="password"
										placeholder="请输入密码"
										class="w-full pl-10 pr-4 py-2.5 rounded-lg bg-background border border-border text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
									/>
								</div>
							</div>

							<!-- 记住我 + 忘记密码 -->
							<div class="flex items-center justify-between text-sm">
								<label class="flex items-center gap-2 cursor-pointer">
									<input type="checkbox" class="w-4 h-4 rounded text-primary focus:ring-primary/30 border-border" />
									<span class="text-muted-foreground">记住我</span>
								</label>
								<a href="/forget" class="text-primary hover:underline transition-all">忘记密码？</a>
							</div>

							<!-- 登录按钮 -->
							<button
								type="submit"
								class="w-full py-2.5 bg-primary text-primary-foreground rounded-lg text-sm font-medium hover:opacity-90 transition-all shadow-sm"
							>
								登录账号
							</button>
						</form>

						<!-- 返回首页 -->
							<div class="flex justify-center">
								<a href="/" class="text-primary hover:underline transition-all">返回首页</a>
							</div>

						<!-- 注册入口 -->
						<div class="text-center text-sm text-muted-foreground">
							还没有账号？
							<a href="/register" class="text-primary font-medium hover:underline transition-all">立即注册</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>